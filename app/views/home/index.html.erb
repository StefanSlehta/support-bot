<div class="container mt-5">
  <h1 class="mb-4">AI Support Bot (PoC)</h1>
  <p class="mb-4">This is a proof-of-concept for an AI support bot that can access your database and help answer customer questions.</p>
  
  <div class="card">
    <div class="card-body">
      <h5 class="card-title">Getting Started</h5>
      <p class="card-text">Add your customers and their database connection strings to start using the support bot.</p>
      <%= link_to "Manage Customers", customers_path, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Chat Support</h5>
          <p class="card-text">Interact with the AI support bot through a chat interface.</p>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Voice Support</h5>
          <p class="card-text">Talk to the AI support bot using voice commands.</p>
        </div>
      </div>
    </div>
  </div>
</div>